REDIS_PASSWORD=change_me

# For local macOS / Windows Docker Desktop, host.docker.internal is usually preferred.
# For Linux servers, replace this with the real host IP or private network IP.
ROCKETMQ_BROKER_IP1=host.docker.internal

SPRING_PROFILES_ACTIVE=default
SERVER_PORT=8080
SPRING_APPLICATION_NAME=backend
BACKEND_IMAGE_NAME=backend:native

SA_TOKEN_TOKEN_NAME=satoken
SA_TOKEN_TIMEOUT=2592000
SA_TOKEN_ACTIVE_TIMEOUT=7200
SA_TOKEN_IS_CONCURRENT=true
SA_TOKEN_IS_SHARE=false
SA_TOKEN_TOKEN_STYLE=random-64
SA_TOKEN_IS_LOG=true

MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=true
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never

OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

CADDY_SITE_ADDRESS=:80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_ACME_EMAIL=ops@example.com
CADDY_GLOBAL_LOG_LEVEL=INFO
CADDY_ACCESS_LOG_LEVEL=INFO
# Keep this aligned with SERVER_PORT when you change the backend container port.
CADDY_UPSTREAM=backend:8080
CADDY_UPSTREAM_HEALTH_URI=/actuator/health
CADDY_UPSTREAM_HEALTH_INTERVAL=30s
CADDY_UPSTREAM_HEALTH_TIMEOUT=5s
CADDY_MAX_REQUEST_BODY=20MB
CADDY_DIAL_TIMEOUT=5s
CADDY_RESPONSE_HEADER_TIMEOUT=30s
CADDY_KEEPALIVE=30s
CADDY_LB_TRY_DURATION=5s
CADDY_LB_TRY_INTERVAL=250ms
CADDY_FAIL_DURATION=30s
CADDY_MAX_FAILS=3
