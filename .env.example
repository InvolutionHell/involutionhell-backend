# --- 数据库（Neon.tech 或其他 PostgreSQL）---
PGHOST=ep-xxxx.ap-southeast-2.aws.neon.tech
PGPORT=5432
PGUSER=neondb_owner
PGPASSWORD=change_me
PGDATABASE=neondb
PGSSLMODE=require

# Spring Boot JDBC 连接（由上面的 PG 变量转换而来）
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx.ap-southeast-2.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_SQL_INIT_MODE=always

# --- Spring Security OAuth2（GitHub 登录）---
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# --- 应用基本设置 ---
SPRING_APPLICATION_NAME=backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default
SPRING_SQL_INIT_MODE=always

# --- Actuator ---
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=true
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# --- 网关（Caddy）---
CADDY_SITE_ADDRESS=:80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_UPSTREAM=backend:8080

# --- Docker 镜像 ---
BACKEND_IMAGE_NAME=ghcr.io/involutionhell/involutionhell-backend:latest
